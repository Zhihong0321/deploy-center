# Example .env file for Deploy Center

# PostgreSQL connection string
# Railway auto-injects this when you add a Postgres database
DATABASE_URL=postgresql://user:password@host:5432/railway

# Railway API token - get from https://railway.app/account/tokens
RAILWAY_TOKEN=your_railway_api_token_here

# GitHub token (optional) - get from https://github.com/settings/tokens
# Needed to fetch commit info. Select 'repo' scope when creating.
GITHUB_TOKEN=your_github_token_here

# How often to poll Railway for updates (seconds)
POLL_INTERVAL_SECONDS=60
